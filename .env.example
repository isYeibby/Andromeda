# ============================================
# VIBE_SYNC — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Get your Client ID at: https://developer.spotify.com/dashboard

# Spotify App Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/callback

# Server Configuration
PORT=3001
CORS_ORIGIN=http://127.0.0.1:5173
CLIENT_URL=http://127.0.0.1:5173

# Client (Vite requires VITE_ prefix for env vars)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_REDIRECT_URI=http://127.0.0.1:3001/callback
VITE_API_URL=http://127.0.0.1:3001
